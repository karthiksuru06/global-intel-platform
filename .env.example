# ─── Redis ───
REDIS_URL=redis://redis:6379

# ─── PostgreSQL / PostGIS ───
POSTGRES_DB=intelligence
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence

# ─── Intelligence Engine ───
INGESTION_INTERVAL_SECONDS=30
CORRELATION_INTERVAL_SECONDS=60
LOG_LEVEL=INFO

# ─── API Gateway ───
PORT=3001
CORS_ORIGIN=http://localhost:5173
INTEL_ENGINE_URL=http://intelligence-engine:8000

# ─── Cesium (optional) ───
# CESIUM_ION_TOKEN=your_cesium_ion_token_here

# ─── Feature 2: Canary Injection ───
CANARY_ENABLED=true
CANARY_INTERVAL_MINUTES=15
CANARY_SECRET=replace-with-high-entropy-secret

# ─── Feature 3: S3 Anchor Replication ───
S3_ANCHOR_ENABLED=false
S3_ANCHOR_BUCKET=your-anchor-bucket
S3_ANCHOR_REGION=us-east-1
S3_ANCHOR_PREFIX=sovereign-anchors/
SOVEREIGN_ANCHOR_KEY=replace-with-anchor-signing-key

# ─── Feature 4: Break-Glass Auth ───
SOVEREIGN_BYPASS_TOKEN=replace-with-bypass-token
SOVEREIGN_SECONDARY_AUTH=replace-with-secondary-auth

# ─── Feature 5: Auth Registry (JSON) ───
# SOVEREIGN_REGISTRY_JSON={"key":{"role":"SOVEREIGN","owner":"Admin","expiresAt":"2027-01-01T00:00:00Z","scopes":["governance","admin"]}}
